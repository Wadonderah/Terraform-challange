# .gitignore

# Terraform state — NEVER commit
*.tfstate
*.tfstate.*
*.tfstate.backup
errored.tfstate

# Terraform plan files — contain sensitive data
*.tfplan

# Terraform working directories
**/.terraform/
**/.terraform.lock.hcl

# Override files
override.tf
override.tf.json
*_override.tf

# Sensitive variable files
*.tfvars.json
!example.tfvars

# OS files
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp
*.swo

# Scripts output
scripts/*.log

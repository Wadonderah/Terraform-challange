# =============================================================================
# Production environment variable values
# IMPORTANT: This file is committed to version control.
# Do NOT put secrets here. Use AWS Secrets Manager or environment variables.
# =============================================================================

aws_region   = "us-east-1"
environment  = "production"
cluster_name = "myapp-prod"

project_name = "MyApp"
team_name    = "platform-engineering"
cost_center  = "CC-1234"

vpc_cidr      = "10.0.0.0/16"
instance_type = "t3.small"
server_port   = 80

min_size         = 2
max_size         = 10
desired_capacity = 2

# Replace these with globally unique names
state_bucket_name   = "myapp-terraform-state-prod-ACCOUNTID"
config_bucket_name  = "myapp-config-prod-ACCOUNTID"
dynamodb_table_name = "terraform-state-lock"

alert_email_addresses = ["platform-team@example.com", "oncall@example.com"]
log_retention_days    = 90

cpu_high_threshold = 80
cpu_low_threshold  = 20

# ACM certificate ARN for HTTPS listener (required for production HTTPS)
# Create via: aws acm request-certificate --domain-name yourdomain.com --validation-method DNS
acm_certificate_arn = "arn:aws:acm:us-east-1:ACCOUNTID:certificate/CERTIFICATE-ID"

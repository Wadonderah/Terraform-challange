# .gitignore

# Terraform state files — NEVER commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan files — contain sensitive data
*.tfplan
ci.tfplan
ci-stage.tfplan
ci-prod.tfplan

# errored state — saved by Terraform when apply fails mid-way
errored.tfstate

# Terraform working directories
**/.terraform/
**/.terraform.lock.hcl

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terragrunt cache
**/.terragrunt-cache/

# Sensitive variable files
*.tfvars
*.tfvars.json
!example.tfvars

# OS files
.DS_Store
Thumbs.db

# Editor files
.idea/
.vscode/
*.swp
*.swo

# Go test cache
tests/integration/vendor/
tests/integration/go.sum

# Lab outputs
labs/**/.terraform/
labs/**/*.tfstate
labs/**/*.tfplan
